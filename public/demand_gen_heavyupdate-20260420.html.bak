Gen","test_type":"Incremental spend-up (BOF/MOF)","treatment_dmas":51,"control_dmas":51,"sf_mm":1.189,"trim_start":"2026-03-14","trim_end":"2026-04-19","full_start":"2026-03-07","full_end":"2026-04-19","pre_start":"2025-12-01","pre_end":"2026-03-06","analysis_date":"2026-04-20","data_through":"2026-04-19","test_still_running":true,"floor_gp":1.4,"floor_topline":2.8},"methodology":{"cross_channel_source":"sales_by_dma_by_channel_ga4.csv (GA4, primary)","ntf_source":"sales_by_dma_by_channel.csv (1P, secondary, includes phone orders)","lc_multiplier_source":"GA4 Google Demand Gen LC ROAS"}};

/* ============================================================
   Palette + Chart.js defaults
   ============================================================ */
const P = {
  navy: '#13213C', navy2: '#1E3665', red: '#A21E22',
  gold: '#C8A646', green: '#2E7D32', gray: '#8B92A3',
  gray100: '#EEF0F4', gray200: '#DCE0E8'
};
const PAL5 = [P.navy, P.red, P.navy2, P.gold, P.green];

Chart.defaults.font.family = '-apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif';
Chart.defaults.font.size = 12;
Chart.defaults.color = '#525868';
Chart.defaults.plugins.legend.position = 'bottom';
Chart.defaults.plugins.legend.labels.usePointStyle = true;
Chart.defaults.plugins.legend.labels.padding = 14;
Chart.defaults.plugins.tooltip.backgroundColor = 'rgba(19,33,60,0.95)';
Chart.defaults.plugins.tooltip.padding = 10;
Chart.defaults.plugins.tooltip.titleFont = { weight: '600', size: 12 };
Chart.defaults.plugins.tooltip.bodyFont = { size: 12 };
Chart.defaults.plugins.tooltip.boxPadding = 4;

/* ============================================================
   Helpers
   ============================================================ */
const fmtD = n => '$' + Math.round(n).toLocaleString('en-US');
const fmtK = n => Math.abs(n) >= 1e6 ? '$' + (n/1e6).toFixed(2) + 'M'
                 : Math.abs(n) >= 1e3 ? '$' + (n/1e3).toFixed(0) + 'k' : fmtD(n);
const fmtN = n => Math.round(n).toLocaleString('en-US');
const fmtP = n => n.toFixed(1) + '%';
const fmtX = n => n.toFixed(2) + 'x';
const fmtByFmt = (v, fmt) => {
  if (fmt === '$') return fmtK(v);
  if (fmt === '%') return v.toFixed(1) + '%';
  if (fmt === 'x') return v.toFixed(2) + 'x';
  if (fmt === 'n') return fmtN(v);
  return v.toString();
};

/* ============================================================
   Meta row
   ============================================================ */
document.getElementById('m-test').textContent = DATA.meta.test_name;
document.getElementById('m-ad').textContent   = DATA.meta.analysis_date;
document.getElementById('m-dt').textContent   = DATA.meta.data_through;
document.getElementById('m-tw').textContent   = DATA.meta.trim_start + ' → ' + DATA.meta.trim_end;
document.getElementById('m-fw').textContent   = DATA.meta.full_start + ' → ' + DATA.meta.full_end;

/* ============================================================
   KPI GRID
   ============================================================ */
const mm = DATA.q1_iroas.find(r => r.window === 'trimmed' && r.model === 'matched_markets');
const mmPrior = DATA.diff_vs_prior.metrics;
const priorO = mmPrior.find(m => m.label.startsWith('Orders iROAS')).prior;
const priorR = mmPrior.find(m => m.label.startsWith('Revenue iROAS')).prior;

const kpis = [
  {
    label: 'Orders iROAS (MM, trimmed)', val: fmtX(mm.iroas_orders),
    delta: 'vs 1.4x floor · prior ' + fmtX(priorO) + ' → now ' + fmtX(mm.iroas_orders),
    hero: true,
    pass: mm.iroas_orders >= 1.4
  },
  {
    label: 'Revenue iROAS (MM, trimmed)', val: fmtX(mm.iroas_revenue),
    delta: 'GP-based · top-line ≈ ' + fmtX(mm.iroas_revenue * 2),
    pass: mm.iroas_revenue >= 1.4
  },
  {
    label: 'Confidence (paired permutation)', val: '~100%',
    delta: 'prior ' + priorO.toFixed(1) + 'x confidence was 98.6% · now tighter',
  },
  {
    label: 'Incremental GP revenue', val: fmtK(mm.inc_revenue),
    delta: fmtN(mm.inc_orders) + ' incremental orders · ' + fmtP(mm.lift_pct_orders) + ' lift',
  }
];

const kgrid = document.getElementById('kpi-grid');
kpis.forEach(k => {
  const d = document.createElement('div');
  d.className = 'kpi' + (k.hero ? ' hero' : '');
  d.innerHTML = `
    <div class="label">${k.label}</div>
    <div class="val">${k.val}</div>
    <div class="delta">${k.delta}</div>
    ${k.pass !== undefined ? `<span class="pass-badge ${k.pass ? 'pass':'fail'}">${k.pass ? '✓ clears floor' : '✗ below floor'}</span>` : ''}
  `;
  kgrid.appendChild(d);
});

/* ============================================================
   HERO CHART (3 models × orders/revenue × window)
   ============================================================ */
let heroModel = 'orders';
let heroWindow = 'trimmed';

function heroData() {
  const rows = DATA.q1_iroas.filter(r => r.window === heroWindow);
  const models = ['matched_markets', 'synthetic_control', 'whole_country'];
  const modelLabels = ['Matched Markets', 'Synthetic Control', 'Whole Country'];
  const vals = models.map(m => rows.find(r => r.model === m));
  const key = heroModel === 'orders' ? 'iroas_orders' : 'iroas_revenue';
  const confKey = heroModel === 'orders' ? 'conf_orders' : 'conf_revenue';
  return {
    labels: modelLabels,
    iroas: vals.map(v => v[key]),
    conf: vals.map(v => v[confKey]),
    incOrders: vals.map(v => v.inc_orders),
    liftPct: vals.map(v => heroModel === 'orders' ? v.lift_pct_orders : v.lift_pct_revenue),
    incSpend: vals.map(v => v.inc_spend),
    incRev: vals.map(v => v.inc_revenue),
    ctrlAov: vals.map(v => v.ctrl_aov)
  };
}

let heroChart;
function renderHero() {
  const d = heroData();
  const ctx = document.getElementById('hero-chart').getContext('2d');
  const colors = d.iroas.map(v => v >= 1.4 ? P.green : (v >= 1.0 ? P.gold : P.red));
  if (heroChart) heroChart.destroy();
  heroChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: d.labels,
      datasets: [{
        label: (heroModel === 'orders' ? 'Orders iROAS' : 'Revenue iROAS') + ' (' + heroWindow + ')',
        data: d.iroas,
        backgroundColor: colors,
        borderRadius: 6,
        maxBarThickness: 120
      }]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => {
              const i = c.dataIndex;
              return [
                'iROAS: ' + fmtX(d.iroas[i]),
                'Confidence: ' + d.conf[i].toFixed(1) + '%',
                'Inc orders: ' + fmtN(d.incOrders[i]) + ' (' + fmtP(d.liftPct[i]) + ' lift)',
                'Inc spend: ' + fmtK(d.incSpend[i]),
                'Inc GP rev: ' + fmtK(d.incRev[i])
              ];
            }
          }
        },
        annotation: {}
      },
      scales: {
        y: {
          beginAtZero: true,
          grid: { color: P.gray100 },
          ticks: { callback: v => v.toFixed(1) + 'x' },
          title: { display: true, text: 'iROAS (GP basis)' }
        },
        x: { grid: { display: false } }
      }
    },
    plugins: [{
      id: 'floorLine',
      afterDraw: (chart) => {
        const {ctx, chartArea: {left, right}, scales: {y}} = chart;
        const yF = y.getPixelForValue(1.4);
        ctx.save();
        ctx.strokeStyle = P.red;
        ctx.setLineDash([6, 4]);
        ctx.lineWidth = 1.5;
        ctx.beginPath(); ctx.moveTo(left, yF); ctx.lineTo(right, yF); ctx.stroke();
        ctx.setLineDash([]);
        ctx.fillStyle = P.red;
        ctx.font = '600 11px -apple-system, sans-serif';
        ctx.fillText('1.4x GP floor', right - 82, yF - 5);
        ctx.restore();
      }
    }]
  });
  renderHeroMath();
}

function renderHeroMath() {
  const d = heroData();
  const rows = d.labels.map((lab, i) => {
    const inc_ord = d.incOrders[i];
    const aov = d.ctrlAov[i];
    const inc_sp = d.incSpend[i];
    return `<tr>
      <td>${lab}</td>
      <td>${fmtN(inc_ord)}</td>
      <td>$${aov.toFixed(2)}</td>
      <td>${fmtK(inc_sp)}</td>
      <td><b>${fmtX(d.iroas[i])}</b></td>
    </tr>`;
  }).join('');
  const headerLabel = heroModel === 'orders' ? 'Inc orders' : 'Inc GP rev';
  const valueCol = heroModel === 'orders'
    ? d.incOrders.map(fmtN)
    : d.incRev.map(fmtK);
  const formulaDesc = heroModel === 'orders'
    ? '(Inc orders × Ctrl AOV) ÷ Inc spend'
    : 'Inc GP revenue ÷ Inc spend';
  document.getElementById('hero-math-table').innerHTML = `
    <p style="margin-top:12px;"><b>Formula (${heroModel}):</b> ${formulaDesc}</p>
    <table>
      <thead><tr><th>Model</th><th>Inc orders</th><th>Ctrl AOV</th><th>Inc spend</th><th>iROAS</th></tr></thead>
      <tbody>${rows}</tbody>
    </table>
  `;
}

document.querySelectorAll('#hero-model-toggle button').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('#hero-model-toggle button').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    heroModel = b.dataset.val;
    renderHero();
  });
});
document.querySelectorAll('#hero-window-toggle button').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('#hero-window-toggle button').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    heroWindow = b.dataset.val;
    renderHero();
  });
});

renderHero();

/* ============================================================
   DIFF TABLE
   ============================================================ */
const diffTbl = document.getElementById('diff-table');
let diffRows = '<thead><tr><th>Metric</th><th>Prior (4/13)</th><th>Current (4/20)</th><th>Δ</th><th>Direction</th></tr></thead><tbody>';
DATA.diff_vs_prior.metrics.forEach(m => {
  const delta = m.current - m.prior;
  const favorable = m.good_higher ? (delta >= 0) : (delta <= 0);
  const arrow = delta > 0 ? '↑' : (delta < 0 ? '↓' : '→');
  const cls = favorable ? 'pos' : 'neg';
  let deltaStr;
  if (m.fmt === '$') deltaStr = (delta >= 0 ? '+' : '') + fmtK(delta);
  else if (m.fmt === '%') deltaStr = (delta >= 0 ? '+' : '') + delta.toFixed(1) + ' pts';
  else if (m.fmt === 'x') deltaStr = (delta >= 0 ? '+' : '') + delta.toFixed(2) + 'x';
  else if (m.fmt === 'n') deltaStr = (delta >= 0 ? '+' : '') + fmtN(delta);
  diffRows += `<tr>
    <td>${m.label}</td>
    <td>${fmtByFmt(m.prior, m.fmt)}</td>
    <td><b>${fmtByFmt(m.current, m.fmt)}</b></td>
    <td class="${cls}">${deltaStr}</td>
    <td class="${cls}">${arrow}</td>
  </tr>`;
});
diffRows += '</tbody>';
diffTbl.innerHTML = diffRows;

/* ============================================================
   WEEKLY SCRUBBER + DOSE-RESPONSE CHART
   ============================================================ */
const weeks = DATA.weekly_trimmed;
const weekLabels = weeks.map(w => 'Wk ' + w.week + ' · ' + w.label);

// scrubber: 0 = all weeks, 1..N = focus that week
const scrub = document.getElementById('week-scrub');
scrub.max = weeks.length;
const weekLabelEl = document.getElementById('week-label');
const readoutEl = document.getElementById('week-readout');

function renderReadout(idx) {
  if (idx === 0) {
    // aggregate
    const sum = weeks.reduce((a,b) => ({
      t_dg_spend: a.t_dg_spend + b.t_dg_spend,
      inc_dg_spend: a.inc_dg_spend + b.inc_dg_spend,
      inc_sessions: a.inc_sessions + b.inc_sessions,
      inc_orders: a.inc_orders + b.inc_orders,
      inc_revenue: a.inc_revenue + b.inc_revenue
    }), {t_dg_spend:0, inc_dg_spend:0, inc_sessions:0, inc_orders:0, inc_revenue:0});
    readoutEl.innerHTML = `
      <div class="sr-item"><div class="l">Inc DG spend</div><div class="v">${fmtK(sum.inc_dg_spend)}</div><div class="d">vs scaled control</div></div>
      <div class="sr-item"><div class="l">Inc sessions</div><div class="v">${fmtN(sum.inc_sessions)}</div><div class="d">vs scaled control</div></div>
      <div class="sr-item"><div class="l">Inc orders</div><div class="v">${fmtN(sum.inc_orders)}</div><div class="d">${fmtP(mm.lift_pct_orders)} lift</div></div>
      <div class="sr-item"><div class="l">Inc GP revenue</div><div class="v">${fmtK(sum.inc_revenue)}</div><div class="d">${fmtP(mm.lift_pct_revenue)} lift</div></div>
    `;
  } else {
    const w = weeks[idx-1];
    readoutEl.innerHTML = `
      <div class="sr-item"><div class="l">Inc DG spend</div><div class="v">${fmtK(w.inc_dg_spend)}</div><div class="d">+${w.heavyup_pct.toFixed(0)}% heavy-up</div></div>
      <div class="sr-item"><div class="l">Inc sessions</div><div class="v">${fmtN(w.inc_sessions)}</div><div class="d">${fmtP(w.lift_sessions)} lift</div></div>
      <div class="sr-item"><div class="l">Inc orders</div><div class="v">${fmtN(w.inc_orders)}</div><div class="d">${fmtP(w.lift_orders)} lift</div></div>
      <div class="sr-item"><div class="l">Inc GP revenue</div><div class="v">${fmtK(w.inc_revenue)}</div><div class="d">${fmtP(w.lift_revenue)} lift</div></div>
    `;
  }
}
renderReadout(0);

scrub.addEventListener('input', (e) => {
  const idx = parseInt(e.target.value, 10);
  weekLabelEl.textContent = idx === 0 ? 'all weeks' : ('Week ' + idx + ' · ' + weeks[idx-1].label);
  renderReadout(idx);
  if (doseChart) {
    doseChart.data.datasets.forEach((ds, i) => {
      ds.pointRadius = weeks.map((w, j) => (idx === 0 ? 4 : (j === idx-1 ? 8 : 3)));
      ds.pointBorderWidth = weeks.map((w, j) => (idx === 0 ? 1 : (j === idx-1 ? 3 : 1)));
    });
    doseChart.update('none');
  }
}, false);

// dose-response: bar for inc_dg_spend, line for inc_sessions
let doseChart;
(function () {
  const ctx = document.getElementById('weekly-dose').getContext('2d');
  doseChart = new Chart(ctx, {
    data: {
      labels: weekLabels,
      datasets: [
        {
          type: 'bar',
          label: 'Incremental DG spend',
          data: weeks.map(w => w.inc_dg_spend),
          backgroundColor: P.navy2,
          yAxisID: 'y',
          borderRadius: 4,
          order: 2
        },
        {
          type: 'line',
          label: 'Incremental sessions',
          data: weeks.map(w => w.inc_sessions),
          borderColor: P.red,
          backgroundColor: P.red,
          yAxisID: 'y1',
          tension: 0.3,
          pointRadius: weeks.map(() => 4),
          pointHoverRadius: 8,
          pointBackgroundColor: P.red,
          borderWidth: 2.5,
          order: 1
        },
        {
          type: 'line',
          label: 'Incremental orders',
          data: weeks.map(w => w.inc_orders),
          borderColor: P.gold,
          backgroundColor: P.gold,
          yAxisID: 'y2',
          tension: 0.3,
          pointRadius: weeks.map(() => 3),
          pointHoverRadius: 7,
          borderWidth: 2,
          hidden: false,
          order: 0
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        tooltip: {
          callbacks: {
            afterBody: (items) => {
              const i = items[0].dataIndex;
              const w = weeks[i];
              return [
                '───────',
                'Heavy-up: +' + w.heavyup_pct.toFixed(0) + '%',
                'Sessions lift: ' + fmtP(w.lift_sessions),
                'Orders lift: ' + fmtP(w.lift_orders),
                'Revenue lift: ' + fmtP(w.lift_revenue)
              ];
            },
            label: (c) => {
              if (c.datasetIndex === 0) return 'Inc DG spend: ' + fmtK(c.parsed.y);
              if (c.datasetIndex === 1) return 'Inc sessions: ' + fmtN(c.parsed.y);
              if (c.datasetIndex === 2) return 'Inc orders: ' + fmtN(c.parsed.y);
            }
          }
        }
      },
      scales: {
        y:  { position: 'left',  title: { display: true, text: 'Inc DG spend ($)' }, grid: { color: P.gray100 }, ticks: { callback: v => fmtK(v) } },
        y1: { position: 'right', title: { display: true, text: 'Inc sessions' }, grid: { drawOnChartArea: false }, ticks: { callback: v => fmtN(v) } },
        y2: { display: false },
        x:  { grid: { display: false } }
      }
    }
  });
})();

/* ============================================================
   SPEND DELTA
   ============================================================ */
(function () {
  const sd = DATA.spend_delta;
  const ctx = document.getElementById('spend-delta').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: sd.map(r => r.channel),
      datasets: [{
        label: 'Delta (treatment − scaled control)',
        data: sd.map(r => r.delta),
        backgroundColor: sd.map(r =>
          r.channel.indexOf('Demand Gen') >= 0 ? P.red : (r.delta > 0 ? P.navy2 : P.gray)
        ),
        borderRadius: 4
      }]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => {
              const r = sd[c.dataIndex];
              return [
                'Delta: ' + fmtK(r.delta) + ' (' + r.pct_delta.toFixed(1) + '%)',
                'Treatment: ' + fmtK(r.treat),
                'Scaled control: ' + fmtK(r.ctrl_scaled)
              ];
            }
          }
        }
      },
      scales: {
        x: { grid: { color: P.gray100 }, ticks: { callback: v => fmtK(v) }, title: { display: true, text: 'Spend delta ($)' } },
        y: { grid: { display: false } }
      }
    }
  });
})();

/* ============================================================
   CROSS-CHANNEL REVENUE (Orders Model vs. Revenue Model)
   ============================================================ */
const ORDERS_AOV = 169.04; // Control-cell AOV (MM trimmed) — matches headline Orders iROAS
let chrevMode = 'orders';
let chrevChart;

function chrevData() {
  // Build rows: channel, inc_orders, inc_rev_orders_model, inc_rev_revenue_model
  const rows = DATA.lc_subchannel.map(r => ({
    channel: r.channel,
    inc_orders: r.inc_orders,
    inc_rev_orders: r.inc_orders * ORDERS_AOV,
    inc_rev_revenue: r.inc_gpm
  }));
  // Rank by abs of selected metric, take top 10
  const key = chrevMode === 'orders' ? 'inc_rev_orders' : 'inc_rev_revenue';
  rows.sort((a, b) => Math.abs(b[key]) - Math.abs(a[key]));
  return rows.slice(0, 10);
}

function renderChrev() {
  const rows = chrevData();
  const key = chrevMode === 'orders' ? 'inc_rev_orders' : 'inc_rev_revenue';
  const ctx = document.getElementById('chrev-chart').getContext('2d');
  if (chrevChart) chrevChart.destroy();
  chrevChart = new Chart(ctx, {
    type: 'bar',
    data: {
      labels: rows.map(r => r.channel),
      datasets: [{
        label: chrevMode === 'orders' ? 'Revenue (Orders Model)' : 'Revenue (Revenue Model)',
        data: rows.map(r => r[key]),
        backgroundColor: rows.map(r => r[key] >= 0 ? P.green : P.red),
        borderRadius: 4
      }]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => {
              const r = rows[c.dataIndex];
              return [
                'Orders Model: ' + fmtK(r.inc_rev_orders),
                'Revenue Model: ' + fmtK(r.inc_rev_revenue),
                'Inc orders: ' + fmtN(r.inc_orders)
              ];
            }
          }
        }
      },
      scales: {
        x: {
          grid: { color: P.gray100 },
          ticks: { callback: v => fmtK(v) },
          title: { display: true, text: chrevMode === 'orders' ? 'Inc revenue = inc orders × $169.04' : 'Inc revenue (observed last-click)' }
        },
        y: { grid: { display: false } }
      }
    }
  });
  renderChrevMath(rows);
}

function renderChrevMath(rows) {
  const body = rows.map(r => `<tr>
    <td>${r.channel}</td>
    <td>${fmtN(r.inc_orders)}</td>
    <td>${fmtK(r.inc_rev_orders)}</td>
    <td>${fmtK(r.inc_rev_revenue)}</td>
    <td>${fmtK(r.inc_rev_revenue - r.inc_rev_orders)}</td>
  </tr>`).join('');
  document.getElementById('chrev-math-table').innerHTML = `
    <p style="margin-top:12px;"><b>Top 10 channels · both models side-by-side</b></p>
    <table>
      <thead><tr>
        <th>Channel</th>
        <th>Inc orders (LC)</th>
        <th>Orders Model $</th>
        <th>Revenue Model $</th>
        <th>Rev − Orders Δ</th>
      </tr></thead>
      <tbody>${body}</tbody>
    </table>
    <p style="margin-top:10px; font-size: 12px; color: var(--gray-600);">Large positive Δ = channel pulled in higher-AOV orders than its order count suggests. Large negative Δ = lower-AOV orders.</p>
  `;
}

document.querySelectorAll('#chrev-toggle button').forEach(b => {
  b.addEventListener('click', () => {
    document.querySelectorAll('#chrev-toggle button').forEach(x => x.classList.remove('active'));
    b.classList.add('active');
    chrevMode = b.dataset.val;
    renderChrev();
  });
});
renderChrev();

/* ============================================================
   NTF
   ============================================================ */
(function () {
  const n = DATA.ntf;
  const ctx = document.getElementById('ntf-chart').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: n.map(r => r.ntf_flag === 'new' ? 'New-to-file' : 'Existing'),
      datasets: [
        {
          label: 'Incremental GP ($)',
          data: n.map(r => r.inc_gpm),
          backgroundColor: n.map(r => r.ntf_flag === 'new' ? P.green : P.gold),
          borderRadius: 6, yAxisID: 'y'
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => {
              const r = n[c.dataIndex];
              return [
                'Inc GP: ' + fmtK(r.inc_gpm),
                'Inc orders (LC): ' + fmtN(r.inc_orders)
              ];
            }
          }
        }
      },
      scales: {
        y: { grid: { color: P.gray100 }, ticks: { callback: v => fmtK(v) }, title: { display: true, text: 'Incremental GP ($)' } },
        x: { grid: { display: false } }
      }
    }
  });
})();

/* ============================================================
   PLACEMENT MIX — stacked area
   ============================================================ */
(function () {
  const mix = DATA.placement_mix_weekly;
  const placements = DATA.placements;
  const ctx = document.getElementById('mix-chart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: mix.map(m => 'Wk ' + m.week),
      datasets: placements.map((p, i) => ({
        label: p,
        data: mix.map(m => m[p]),
        fill: true,
        backgroundColor: PAL5[i % PAL5.length] + 'cc',
        borderColor: PAL5[i % PAL5.length],
        tension: 0.3,
        pointRadius: 3,
        pointHoverRadius: 6,
        borderWidth: 1.5,
        stack: 'mix'
      }))
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        tooltip: {
          callbacks: {
            label: (c) => c.dataset.label + ': ' + c.parsed.y.toFixed(1) + '%'
          }
        }
      },
      scales: {
        y: { stacked: true, min: 0, max: 100, grid: { color: P.gray100 }, ticks: { callback: v => v + '%' }, title: { display: true, text: 'Share of DG spend (%)' } },
        x: { grid: { display: false } }
      }
    }
  });
})();

/* ============================================================
   SAME-DAY + LEAD-LAG CORRELATIONS
   ============================================================ */
function corrChart(canvasId, rows) {
  const ctx = document.getElementById(canvasId).getContext('2d');
  const sorted = [...rows].sort((a,b) => b.r - a.r);
  return new Chart(ctx, {
    type: 'bar',
    data: {
      labels: sorted.map(r => r.placement),
      datasets: [{
        label: 'Pearson r',
        data: sorted.map(r => r.r),
        backgroundColor: sorted.map(r => r.r > 0.3 ? P.green : (r.r > 0 ? P.gold : P.red)),
        borderRadius: 4
      }]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: (c) => 'r = ' + c.parsed.x.toFixed(3) + (sorted[c.dataIndex].n !== undefined ? ' (n=' + sorted[c.dataIndex].n + ')' : '') } }
      },
      scales: {
        x: { min: -0.3, max: 0.8, grid: { color: P.gray100 }, title: { display: true, text: 'Correlation with inc orders' } },
        y: { grid: { display: false } }
      }
    }
  });
}
corrChart('sameday-chart', DATA.sameday_corr);
corrChart('leadlag-chart', DATA.lead_lag);

/* ============================================================
   LC ROAS GAUGE + TABLE
   ============================================================ */
(function () {
  const lc = DATA.lc_multiplier;
  // Gauge: doughnut with current LC ROAS marker
  const ctx = document.getElementById('lc-gauge').getContext('2d');
  const cur = lc.hu_dg_lc_roas_treat;       // 0.463
  const warn = lc.warn_threshold_orders;     // 0.444 (orders)
  const warnBau = lc.warn_threshold_bau;     // 0.396
  const max = 1.0;
  const toPct = v => Math.min(1, v / max);

  // Simple horizontal bar gauge using bar chart
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: ['Current DG LC ROAS (treatment)', 'Warn threshold (orders model)', 'Warn threshold (BAU baseline)'],
      datasets: [{
        data: [cur, warn, warnBau],
        backgroundColor: [
          cur >= warn ? P.green : P.red,
          P.gold,
          P.red
        ],
        borderRadius: 5
      }]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: (c) => c.parsed.x.toFixed(3) + 'x' } }
      },
      scales: {
        x: { min: 0, max: 0.8, grid: { color: P.gray100 }, ticks: { callback: v => v.toFixed(2) + 'x' }, title: { display: true, text: 'LC ROAS' } },
        y: { grid: { display: false } }
      }
    }
  });

  // Table
  const lcRows = [
    ['BAU LC ROAS (pre-test baseline)', fmtX(lc.bau_lc_roas)],
    ['BAU true iROAS (prior test)', fmtX(lc.bau_true_iroas)],
    ['BAU multiplier', fmtX(lc.bau_mult)],
    ['', ''],
    ['Heavy-up DG LC ROAS (treatment)', fmtX(lc.hu_dg_lc_roas_treat)],
    ['Heavy-up DG LC ROAS (control)', fmtX(lc.hu_dg_lc_roas_ctrl)],
    ['Heavy-up true iROAS (orders)', fmtX(lc.hu_true_iroas_orders)],
    ['Heavy-up multiplier (orders)', fmtX(lc.hu_mult_orders)],
    ['', ''],
    ['Warn threshold (BAU baseline)', fmtX(lc.warn_threshold_bau)],
    ['Warn threshold (orders model)', fmtX(lc.warn_threshold_orders)]
  ];
  document.getElementById('lc-table').innerHTML = '<tbody>' + lcRows.map(r =>
    `<tr><td>${r[0]}</td><td><b>${r[1]}</b></td></tr>`
  ).join('') + '</tbody>';
  document.getElementById('mult-show').textContent = fmtX(lc.hu_mult_orders);
})();

/* ============================================================
   INDUSTRY BENCHMARKS
   ============================================================ */
(function () {
  const b = DATA.benchmarks;
  const ctx = document.getElementById('bench-chart').getContext('2d');
  new Chart(ctx, {
    type: 'bar',
    data: {
      labels: b.map(r => r.name),
      datasets: [{
        data: b.map(r => r.value),
        backgroundColor: b.map(r => r.us ? P.red : P.navy2),
        borderRadius: 5
      }]
    },
    options: {
      indexAxis: 'y', responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (c) => {
              const row = b[c.dataIndex];
              return [row.value.toFixed(2) + 'x (top-line)', row.source];
            }
          }
        }
      },
      scales: {
        x: { grid: { color: P.gray100 }, ticks: { callback: v => v.toFixed(1) + 'x' }, title: { display: true, text: 'iROAS (top-line)' } },
        y: { grid: { display: false } }
      }
    }
  });
})();

/* ============================================================
   PRE-PERIOD DAILY FIT
   ============================================================ */
(function () {
  const p = DATA.preperiod_daily_mm;
  const ctx = document.getElementById('pp-chart').getContext('2d');
  new Chart(ctx, {
    type: 'line',
    data: {
      labels: p.map(r => r.date),
      datasets: [
        {
          label: 'Treatment (actual)',
          data: p.map(r => r.treat),
          borderColor: P.red,
          backgroundColor: P.red,
          tension: 0.25,
          pointRadius: 0,
          borderWidth: 1.75
        },
        {
          label: 'Scaled control (counterfactual)',
          data: p.map(r => r.ctrl_scaled),
          borderColor: P.navy2,
          backgroundColor: P.navy2,
          tension: 0.25,
          pointRadius: 0,
          borderWidth: 1.75,
          borderDash: [4, 4]
        }
      ]
    },
    options: {
      responsive: true, maintainAspectRatio: false,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        tooltip: { callbacks: { label: (c) => c.dataset.label + ': ' + fmtN(c.parsed.y) + ' orders' } }
      },
      scales: {
        y: { grid: { color: P.gray100 }, ticks: { callback: v => fmtN(v) }, title: { display: true, text: 'Daily orders' } },
        x: { grid: { display: false }, ticks: { maxRotation: 0, autoSkip: true, maxTicksLimit: 10 } }
      }
    }
  });

  // pp-table
  const pr = DATA.preperiod;
  const rows = pr.map(r =>
    `<tr>
      <td>${r.name.replace('_', ' ')}</td>
      <td>${r.sf.toFixed(4)}</td>
      <td>${r.orders_mape.toFixed(2)}%</td>
      <td>${r.orders_corr.toFixed(4)}</td>
      <td>${r.revenue_mape.toFixed(2)}%</td>
      <td>${r.revenue_corr.toFixed(4)}</td>
    </tr>`
  ).join('');
  document.getElementById('pp-table').innerHTML = `
    <thead><tr>
      <th>Model</th><th>Scale factor</th><th>Orders MAPE</th><th>Orders r</th><th>Revenue MAPE</th><th>Revenue r</th>
    </tr></thead>
    <tbody>${rows}</tbody>
  `;
})();

</script>
</body>
</html>